{
  "info": {
    "name": "Leave Management System API",
    "description": "Complete API collection for the Employee Leave Management System. Set the `baseUrl` and `accessToken` collection variables after logging in.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "accessToken", "value": "" },
    { "key": "leaveId", "value": "" },
    { "key": "employeeId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Employee)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"employee@company.com\",\n  \"password\": \"Employee@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login (Manager)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manager@company.com\",\n  \"password\": \"Manager@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Refresh Token",
          "request": { "method": "POST", "url": "{{baseUrl}}/auth/refresh" }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "List Employees (Manager only)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/employees?search=&department=&page=1&limit=10"
          }
        },
        {
          "name": "Get Employee By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/employees/{{employeeId}}"
          }
        },
        {
          "name": "Get Employee Leave History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/employees/{{employeeId}}/leave-history"
          }
        }
      ]
    },
    {
      "name": "Leaves (Employee)",
      "item": [
        {
          "name": "Apply for Leave",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leaveType\": \"Sick\",\n  \"startDate\": \"2026-08-01\",\n  \"endDate\": \"2026-08-02\",\n  \"reason\": \"Feeling unwell, need rest\"\n}"
            },
            "url": "{{baseUrl}}/leaves"
          }
        },
        {
          "name": "Get My Leave History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/leaves?status=&leaveType=&page=1&limit=10"
          }
        },
        {
          "name": "Get Leave By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/leaves/{{leaveId}}"
          }
        },
        {
          "name": "Edit Pending Leave",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Updated reason for leave\"\n}" },
            "url": "{{baseUrl}}/leaves/{{leaveId}}"
          }
        },
        {
          "name": "Cancel Pending Leave",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/leaves/{{leaveId}}"
          }
        },
        {
          "name": "Employee Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/leaves/dashboard/stats"
          }
        }
      ]
    },
    {
      "name": "Manager Operations",
      "item": [
        {
          "name": "Get Pending Leaves",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/pending-leaves?search=&leaveType=&page=1&limit=10"
          }
        },
        {
          "name": "Approve Leave",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"managerComments\": \"Approved, enjoy!\"\n}" },
            "url": "{{baseUrl}}/leaves/{{leaveId}}/approve"
          }
        },
        {
          "name": "Reject Leave",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"managerComments\": \"Team is short-staffed that week\"\n}" },
            "url": "{{baseUrl}}/leaves/{{leaveId}}/reject"
          }
        },
        {
          "name": "Manager Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/manager/dashboard/stats"
          }
        }
      ]
    }
  ]
}
